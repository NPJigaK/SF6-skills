    "drive_regeneration_rates": [
      {
        "state": "Base Drive Regen (Passive)",
        "source_regen_value": "40 / 24% [50 / 30%]",
        "notes": "In Burnout, blocking adds to Drive Gauge rather than depleting it"
      },
      {
        "state": "In Hitstun",
        "source_regen_value": "20 / 12% [25 / 15%]",
        "notes": "Applies to any hitstun, including grounded hits, knockdowns, air resets, air juggles, throws, etc. After being knocked down, the Normal Rise and Back Rise animations go back to the Base Drive Regen rate"
      },
      {
        "state": "Jumping",
        "source_regen_value": "20 / 12%",
        "notes": "Includes airborne frames of attacks, such as Chun-Li or Kimberly 6HK Jumping during Burnout is especially detrimental to the Drive Regen rate"
      },
      {
        "state": "Walking Forward",
        "source_regen_value": "+20 / +12% (11f~: Base x2)",
        "notes": "Stacks with Base Drive Regen (Total: 60 Drive/frame); works even during Drive Regen Cooldown Meter build starts on frame 2, so a 2-frame microwalk can enable otherwise impossible combos (e.g. Drive Rush Cancel x3) Applies even during Burnout (Total: 70 Drive/frame), so an offensive playstyle can help to recover more quickly Starting on Frame 11 of Forward Walk, your Base Drive Regen is doubled for every additional walking frame This is a separate bonus from the usual +20/frame from walking forward A character in Drive Regen Cooldown has a Base Drive Regen of 0 which and will not benefit Standard Formula: 40 Regen/Frame x2 + 20 = 100 Drive/Frame, or 0.6 Drive Bars per second Burnout Formula: 50 Regen/Frame x2 + 20 = 120 Drive/Frame, or 0.72 Drive Bars per second Does not help meter build after a DI Stun, as Drive Regen Cooldown lasts too long"
      }
    ],
