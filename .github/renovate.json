{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "labels": [
    "dependencies"
  ],
  "dependencyDashboard": true,
  "timezone": "Asia/Tokyo",
  "lockFileMaintenance": {
    "enabled": true
  },
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update the Renovate Docker image version used by the Renovate workflow.",
      "managerFilePatterns": [
        "/^\\.github\\/workflows\\/renovate\\.ya?ml$/"
      ],
      "matchStrings": [
        "renovate-version:\\s*(?<currentValue>\\S+)\\s+#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "nix"
      ],
      "groupName": "Hermes Agent Nix flake input",
      "labels": [
        "dependencies",
        "toolchain",
        "hermes"
      ]
    },
    {
      "matchManagers": [
        "mise"
      ],
      "groupName": "maintainer toolchain",
      "postUpgradeTasks": {
        "commands": [
          "bash .github/renovate-mise-lock.sh"
        ],
        "fileFilters": [
          "mise.lock"
        ],
        "executionMode": "branch"
      }
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github actions"
    },
    {
      "matchDatasources": [
        "pypi"
      ],
      "groupName": "python dependencies"
    }
  ]
}
