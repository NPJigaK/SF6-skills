{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sf6-knowledge-agent-kit.local/eval-case.schema.json",
  "title": "Eval Case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "question",
    "expected_answer_mode",
    "evidence_boundary",
    "must_not_include"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "expected_answer_mode": {
      "enum": [
        "stable_concept",
        "verified_current_fact",
        "strategy_or_matchup_knowledge",
        "observation",
        "unresolved_or_hold"
      ]
    },
    "evidence_boundary": {
      "type": "string",
      "minLength": 1
    },
    "must_not_include": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
