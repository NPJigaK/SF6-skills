{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sf6-knowledge-agent-kit.local/agent-toolchain.schema.json",
  "title": "Agent Toolchain",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "last_reviewed",
    "tools",
    "boundaries"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "agent-toolchain/v1"
    },
    "last_reviewed": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "role",
          "recommended_channel",
          "known_good_version",
          "required_capabilities",
          "planned_capabilities",
          "version_command",
          "version_command_review_note",
          "update_guidance",
          "freshness_review_cadence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "codex-cli",
              "hermes-cli"
            ]
          },
          "role": {
            "type": "string",
            "enum": [
              "repo_implementation_executor",
              "repo_local_growth_engine"
            ]
          },
          "recommended_channel": {
            "type": "string",
            "enum": [
              "latest_stable",
              "known_good",
              "manual_review_required"
            ]
          },
          "known_good_version": {
            "type": [
              "string",
              "null"
            ]
          },
          "required_capabilities": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "planned_capabilities": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "version_command": {
            "type": [
              "string",
              "null"
            ]
          },
          "version_command_review_note": {
            "type": "string",
            "minLength": 1
          },
          "update_guidance": {
            "type": "string",
            "minLength": 1
          },
          "freshness_review_cadence": {
            "type": "string",
            "minLength": 1
          },
          "version_management": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "primary_pin_surface",
              "primary_update_surface",
              "flake_input",
              "flake_input_url",
              "manual_update_command",
              "fallback_local_check_commands",
              "fallback_local_update_command",
              "local_output_policy"
            ],
            "properties": {
              "primary_pin_surface": {
                "type": "string",
                "enum": [
                  "nix_flake_lock"
                ]
              },
              "primary_update_surface": {
                "type": "string",
                "enum": [
                  "renovate_nix_flake_pr"
                ]
              },
              "flake_input": {
                "type": "string",
                "const": "hermes-agent"
              },
              "flake_input_url": {
                "type": "string",
                "const": "github:NousResearch/hermes-agent"
              },
              "manual_update_command": {
                "type": "string",
                "const": "nix flake update hermes-agent"
              },
              "fallback_local_check_commands": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "enum": [
                    "hermes --version",
                    "hermes doctor"
                  ]
                },
                "uniqueItems": true
              },
              "fallback_local_update_command": {
                "type": "string",
                "const": "hermes update"
              },
              "local_output_policy": {
                "type": "string",
                "const": "local_command_output_is_noncanonical_review_signal"
              }
            }
          },
          "maintainer_profile_policy": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "profile_expectation_scope",
              "profile_names",
              "required_model",
              "accepted_model_aliases",
              "required_reasoning_effort",
              "accepted_reasoning_effort_aliases",
              "reasoning_effort_requirement_mode",
              "profile_check_commands",
              "profile_check_output_policy",
              "skill_selection_policy"
            ],
            "properties": {
              "profile_expectation_scope": {
                "type": "string",
                "const": "repo_maintainer_profiles_only"
              },
              "profile_names": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "uniqueItems": true
              },
              "required_model": {
                "type": "string",
                "minLength": 1
              },
              "accepted_model_aliases": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "uniqueItems": true
              },
              "required_reasoning_effort": {
                "type": "string",
                "enum": [
                  "xhigh"
                ]
              },
              "accepted_reasoning_effort_aliases": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "enum": [
                    "xhigh",
                    "extra-high",
                    "extra_high"
                  ]
                },
                "uniqueItems": true
              },
              "reasoning_effort_requirement_mode": {
                "type": "string",
                "enum": [
                  "required_when_supported",
                  "manual_review_required",
                  "not_applicable"
                ]
              },
              "profile_check_commands": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "enum": [
                    "hermes profile list",
                    "hermes profile show sf6ingest"
                  ]
                },
                "uniqueItems": true
              },
              "profile_check_output_policy": {
                "type": "string",
                "const": "local_profile_output_is_noncanonical_review_signal"
              },
              "skill_selection_policy": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "selection_scope",
                  "selection_status",
                  "applies_to_profile",
                  "hub_context",
                  "purpose",
                  "default_builtin_skills",
                  "conditional_builtin_skills",
                  "forbidden_skill_categories",
                  "skill_review_commands",
                  "skill_review_output_policy"
                ],
                "properties": {
                  "selection_scope": {
                    "type": "string",
                    "const": "repo_maintainer_profiles_only"
                  },
                  "selection_status": {
                    "type": "string",
                    "const": "policy_expectation_not_runtime_state"
                  },
                  "applies_to_profile": {
                    "type": "string",
                    "const": "sf6ingest"
                  },
                  "hub_context": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "source",
                      "last_reviewed",
                      "advertised_total_skills",
                      "advertised_builtin_skills",
                      "narrowing_reason"
                    ],
                    "properties": {
                      "source": {
                        "type": "string",
                        "const": "Hermes Skills Hub"
                      },
                      "last_reviewed": {
                        "type": "string",
                        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                      },
                      "advertised_total_skills": {
                        "type": "integer",
                        "minimum": 1
                      },
                      "advertised_builtin_skills": {
                        "type": "integer",
                        "minimum": 1
                      },
                      "narrowing_reason": {
                        "type": "string",
                        "minLength": 1
                      }
                    }
                  },
                  "purpose": {
                    "type": "string",
                    "minLength": 1
                  },
                  "default_builtin_skills": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "minLength": 1
                    },
                    "uniqueItems": true
                  },
                  "conditional_builtin_skills": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    },
                    "uniqueItems": true
                  },
                  "forbidden_skill_categories": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "minLength": 1
                    },
                    "uniqueItems": true
                  },
                  "skill_review_commands": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "enum": [
                        "hermes skills list",
                        "hermes skills inspect hermes-agent"
                      ]
                    },
                    "uniqueItems": true
                  },
                  "skill_review_output_policy": {
                    "type": "string",
                    "const": "local_skill_output_is_noncanonical_review_signal"
                  }
                }
              }
            }
          }
        }
      }
    },
    "boundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
