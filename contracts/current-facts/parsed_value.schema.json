{
  "$id": "https://sf6-knowledge-coach.local/schemas/current-facts/parsed_value.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "integer" },
        "unit": { "type": "string" },
        "value": { "type": "integer" }
      },
      "required": ["kind", "value"],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "decimal" },
        "unit": { "type": "string" },
        "value": { "type": "number" }
      },
      "required": ["kind", "value"],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "signed_frame" },
        "unit": { "const": "frame" },
        "value": { "type": "integer" }
      },
      "required": ["kind", "unit", "value"],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "end": { "type": "integer" },
        "kind": { "const": "frame_range" },
        "start": { "type": "integer" },
        "unit": { "const": "frame" }
      },
      "required": ["end", "kind", "start", "unit"],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "ordered_pair" },
        "labels": {
          "items": { "type": "string" },
          "maxItems": 2,
          "minItems": 2,
          "type": "array"
        },
        "unit": { "type": "string" },
        "values": {
          "items": { "type": "number" },
          "maxItems": 2,
          "minItems": 2,
          "type": "array"
        }
      },
      "required": ["kind", "labels", "values"],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "percent" },
        "unit": { "const": "percent" },
        "value": { "type": "number" }
      },
      "required": ["kind", "unit", "value"],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "gauge_amount" },
        "unit": { "enum": ["drive", "super_art"] },
        "value": { "type": "number" }
      },
      "required": ["kind", "unit", "value"],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "enum_token" },
        "tokens": {
          "items": { "type": "string" },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": ["kind", "tokens"],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "raw_note" },
        "text": { "type": "string" }
      },
      "required": ["kind", "text"],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "annotation": {
          "additionalProperties": false,
          "properties": {
            "marker_placement": { "enum": ["prefix", "suffix"] },
            "note_id": { "type": ["string", "null"] },
            "note_linkage_status": {
              "enum": ["same_row_note_candidates_available"]
            },
            "note_marker": { "const": "※" },
            "note_scope": {
              "enum": [
                "row_startup_condition",
                "row_block_advantage_condition",
                "row_hit_advantage_condition"
              ]
            },
            "note_text_status": { "const": "structured_row_note_text_found" },
            "row_note_candidate_count": {
              "minimum": 1,
              "type": "integer"
            }
          },
          "required": [
            "marker_placement",
            "note_id",
            "note_linkage_status",
            "note_marker",
            "note_scope",
            "note_text_status",
            "row_note_candidate_count"
          ],
          "type": "object"
        },
        "calculation": {
          "additionalProperties": false,
          "properties": {
            "calculation_input_status": {
              "const": "annotated_candidate_not_calculation_safe"
            },
            "reason": { "const": "condition_bound_by_official_note" }
          },
          "required": ["calculation_input_status", "reason"],
          "type": "object"
        },
        "kind": { "const": "annotated_numeric_candidate" },
        "numeric_candidate": {
          "additionalProperties": false,
          "properties": {
            "candidate_type": { "enum": ["unsigned_frame", "signed_frame"] },
            "unit": { "const": "frame" },
            "value": { "type": "integer" }
          },
          "required": ["candidate_type", "unit", "value"],
          "type": "object"
        },
        "source_context": {
          "additionalProperties": false,
          "properties": {
            "review_item_id": {
              "pattern": "^[a-z0-9][a-z0-9_.:-]*$",
              "type": "string"
            },
            "source_column_header_path": {
              "items": { "type": "string" },
              "minItems": 1,
              "type": "array"
            },
            "source_review_id": {
              "pattern": "^[a-z0-9][a-z0-9_.:-]*$",
              "type": "string"
            }
          },
          "required": [
            "review_item_id",
            "source_column_header_path",
            "source_review_id"
          ],
          "type": "object"
        }
      },
      "required": [
        "annotation",
        "calculation",
        "kind",
        "numeric_candidate",
        "source_context"
      ],
      "type": "object"
    }
  ],
  "title": "Parsed current-fact value"
}
