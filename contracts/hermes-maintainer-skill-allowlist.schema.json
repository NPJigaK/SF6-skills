{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sf6-knowledge-agent-kit.local/hermes-maintainer-skill-allowlist.schema.json",
  "title": "Hermes Maintainer Skill Allowlist",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "last_reviewed",
    "tracking_issue",
    "profile",
    "scope",
    "status",
    "public_distribution_boundary",
    "local_state_boundary",
    "default_activation_rule",
    "builtin_default_skills",
    "builtin_conditional_skills",
    "external_apm_skills",
    "deferred_candidates",
    "forbidden_categories",
    "review_commands",
    "source_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "hermes-maintainer-skill-allowlist/v1"
    },
    "last_reviewed": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "tracking_issue": {
      "type": "string",
      "pattern": "^#[0-9]+$"
    },
    "profile": {
      "const": "sf6ingest"
    },
    "scope": {
      "const": "repo_maintainer_profiles_only"
    },
    "status": {
      "const": "policy_expectation_not_runtime_state"
    },
    "public_distribution_boundary": {
      "const": "public_sf6_agent_distribution_deferred"
    },
    "local_state_boundary": {
      "const": "do_not_commit_local_hermes_profile_state"
    },
    "default_activation_rule": {
      "type": "string",
      "minLength": 1
    },
    "builtin_default_skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/builtinDefaultSkill"
      }
    },
    "builtin_conditional_skills": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/builtinConditionalSkill"
      }
    },
    "external_apm_skills": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/externalApmSkill"
      }
    },
    "deferred_candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/deferredCandidate"
      }
    },
    "forbidden_categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/forbiddenCategory"
      }
    },
    "review_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "hermes skills list",
          "hermes skills inspect hermes-agent"
        ]
      },
      "uniqueItems": true
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "skillBase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source_kind",
        "activation",
        "reason",
        "authority_boundary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "source_kind": {
          "type": "string"
        },
        "activation": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "authority_boundary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "builtinDefaultSkill": {
      "allOf": [
        {
          "$ref": "#/$defs/skillBase"
        },
        {
          "type": "object",
          "properties": {
            "source_kind": {
              "const": "builtin_default"
            }
          }
        }
      ]
    },
    "builtinConditionalSkill": {
      "allOf": [
        {
          "$ref": "#/$defs/skillBase"
        },
        {
          "type": "object",
          "properties": {
            "source_kind": {
              "const": "builtin_conditional"
            }
          }
        }
      ]
    },
    "externalApmSkill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source_kind",
        "source_manifest",
        "lockfile",
        "dependency",
        "virtual_path",
        "pin_policy",
        "activation",
        "reason",
        "authority_boundary",
        "public_answer_boundary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "source_kind": {
          "const": "external_apm"
        },
        "source_manifest": {
          "const": "tools/agent-skills/apm.yml"
        },
        "lockfile": {
          "const": "tools/agent-skills/apm.lock.yaml"
        },
        "dependency": {
          "type": "string",
          "minLength": 1
        },
        "virtual_path": {
          "type": "string",
          "minLength": 1
        },
        "pin_policy": {
          "const": "reviewed_tag_or_immutable_sha_required"
        },
        "activation": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "authority_boundary": {
          "type": "string",
          "minLength": 1
        },
        "public_answer_boundary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "deferredCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source_kind",
        "reason",
        "required_before_adoption"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "source_kind": {
          "const": "deferred_candidate"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "required_before_adoption": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "forbiddenCategory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "reason"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
