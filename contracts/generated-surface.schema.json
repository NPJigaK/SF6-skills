{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sf6-knowledge-agent-kit.local/generated-surface.schema.json",
  "title": "Generated Surface",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated",
    "generator",
    "source_paths",
    "target_path"
  ],
  "properties": {
    "generated": {
      "const": true
    },
    "generator": {
      "type": "string",
      "minLength": 1
    },
    "source_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "target_path": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string"
    }
  }
}
