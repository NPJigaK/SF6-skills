{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sf6-knowledge-agent-kit.local/video-observation.schema.json",
  "title": "Video Observation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "clip_metadata",
    "actor_bindings",
    "segments"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0.0"
    },
    "clip_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clip_id",
        "normalized_fps",
        "total_frames"
      ],
      "properties": {
        "clip_id": {
          "type": "string",
          "minLength": 1
        },
        "source_fps": {
          "type": [
            "number",
            "null"
          ]
        },
        "normalized_fps": {
          "const": 60
        },
        "total_frames": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "actor_bindings": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "actor_ref",
          "character_slug",
          "binding_confidence",
          "binding_basis"
        ],
        "properties": {
          "actor_ref": {
            "enum": [
              "actor_a",
              "actor_b"
            ]
          },
          "character_slug": {
            "type": [
              "string",
              "null"
            ]
          },
          "binding_confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "binding_basis": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "segment_id",
          "track",
          "kind",
          "start_frame",
          "end_frame",
          "confidence",
          "evidence_refs"
        ],
        "properties": {
          "segment_id": {
            "type": "string"
          },
          "track": {
            "enum": [
              "actor_a_local",
              "actor_b_local",
              "interaction",
              "global_phase",
              "key_display",
              "transcript"
            ]
          },
          "kind": {
            "type": "string"
          },
          "start_frame": {
            "type": "integer",
            "minimum": 0
          },
          "end_frame": {
            "type": "integer",
            "minimum": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    },
    "derived_events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "event_id",
          "kind",
          "source_segment_ids"
        ]
      }
    }
  }
}
